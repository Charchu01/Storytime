# ── Required: Core API keys ──────────────────────────────────────────────────
ANTHROPIC_KEY=your_anthropic_api_key_here
REPLICATE_KEY=your_replicate_api_key_here

# ── Optional: Supabase (book storage, admin dashboard) ──────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Optional: Clerk (authentication) ────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# ── Optional: Stripe (payments) ─────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ── Optional: ElevenLabs (narration) ────────────────────────────────────────
ELEVENLABS_KEY=your_elevenlabs_api_key

# ── Optional: Admin ─────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@example.com
ADMIN_PASSWORD=your_admin_password

# ── Optional: Client-side Supabase (public, for direct queries) ─────────────
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
